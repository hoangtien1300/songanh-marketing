# Song Anh Marketing - Environment Variables Example
# Copy this file to .env and fill in the values

# Notion API
NOTION_API_TOKEN=your_notion_token_here

# Facebook Marketing API
FB_ACCESS_TOKEN=your_fb_page_access_token_here

# Google Sheets Service Account (JSON string)
# Copy the entire content of your .json key file into this variable (as a single line or escaped string)
GOOGLE_AUTH_JSON={"type": "service_account", "project_id": "...", ...}
